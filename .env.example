# Supabase option:
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Self-hosted PostgreSQL option:
# DATABASE_URL=postgresql://postgres:<url-encoded-password>@localhost:5432/sqb_erp
# DIRECT_DATABASE_URL=postgresql://postgres:<url-encoded-password>@localhost:5432/sqb_erp
API_HOST=0.0.0.0
API_PORT=4000
PLATFORM_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
REDIS_URL=redis://localhost:6379
ALLOW_DEMO_AUTH=true
SESSION_COOKIE_NAME=erp_session
OTP_TTL_SECONDS=300
OTP_ISSUER=SQB Business OS
OTP_TOTP_WINDOW=1
OTP_SMS_PROVIDER=log
JWT_SECRET=dev-secret-change-in-production-minimum-32-chars!!
REFRESH_TOKEN_TTL_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# DATABASE_URL should be the runtime database connection.
# DIRECT_DATABASE_URL should be the Prisma/admin direct connection.
# On Supabase, use the Session Pooler for DATABASE_URL and the direct DB host for DIRECT_DATABASE_URL.
# On self-hosted PostgreSQL, both can point to the same database server.
# Reserved characters in DB passwords must be URL-encoded in both URLs.
# Example: + becomes %2B, { becomes %7B, } becomes %7D, > becomes %3E, , becomes %2C, @ becomes %40.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY are not used by the current auth flow.
