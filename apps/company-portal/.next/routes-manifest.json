{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/tenants/invites/[inviteId]/revoke",
      "regex": "^/api/tenants/invites/([^/]+?)/revoke(?:/)?$",
      "routeKeys": {
        "nxtPinviteId": "nxtPinviteId"
      },
      "namedRegex": "^/api/tenants/invites/(?<nxtPinviteId>[^/]+?)/revoke(?:/)?$"
    },
    {
      "page": "/api/tenants/members/[userId]",
      "regex": "^/api/tenants/members/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/api/tenants/members/(?<nxtPuserId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/app/finance/bills/[id]",
