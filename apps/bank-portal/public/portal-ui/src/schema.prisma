generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// D2 — SMB Operations Models

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String   @unique
  name        String
  category    String
  stock       Int      @default(0)
  minStock    Int      @default(0)
  unitPrice   Decimal  @db.Decimal(18, 2)
  status      String   // e.g., "IN_STOCK", "LOW", "OUT_OF_STOCK"
  movements   StockMovement[]
  bomItems    BOMComponent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String   // RECEIVED, SALE, ADJUSTMENT, PRODUCTION_CONSUMPTION
  quantity  Int
  reference String?  // e.g., "WB-23887" or "PO-0451"
  createdAt DateTime @default(now())
}

model BOM {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   @unique // e.g., "BOM-01"
  recipeName  String
  outputRate  String   // e.g., "120/day"
  unitCost    Decimal  @db.Decimal(18, 2)
  status      String   @default("ACTIVE")
  components  BOMComponent[]
  orders      ProductionOrder[]
}

model BOMComponent {
  id        String  @id @default(cuid())
  bomId     String
  bom       BOM     @relation(fields: [bomId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}

model ProductionOrder {
  id          String   @id @default(cuid())
  tenantId    String
  bomId       String
  bom         BOM      @relation(fields: [bomId], references: [id])
  status      String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED
  plannedQty  Int
  completedQty Int     @default(0)
  scrapQty    Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
}

model WorkOrder {
  id        String   @id @default(cuid())
  tenantId  String
  customer  String
  task      String
  assignee  String
  status    String   @default("REQUESTED") // REQUESTED, APPROVED, IN_PROGRESS, COMPLETED
  createdAt DateTime @default(now())
}